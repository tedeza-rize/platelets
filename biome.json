{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!node_modules", "!.next", "!dist", "!build"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "all",
      "correctness": {
        "noNodejsModules": "off",
        "noProcessGlobal": "off",
        "noUnresolvedImports": "off",
        "useImportExtensions": "off"
      },
      "nursery": {
        "noFloatingPromises": "error",
        "noMisusedPromises": "error",
        "useImportsFirst": "error"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 30
          }
        },
        "noExcessiveLinesPerFunction": {
          "level": "error",
          "options": {
            "maxLines": 150,
            "skipBlankLines": true
          }
        },
        "noUselessUndefined": "error",
        "noVoid": "off",
        "useMaxParams": "off",
        "useOptionalChain": "error",
        "useSimplifiedLogicExpression": "error"
      },
      "suspicious": {
        "noConsole": "off",
        "noEmptyBlockStatements": "error",
        "noAlert": "error",
        "noBitwiseOperators": "off",
        "noEvolvingTypes": "error",
        "noLeakedRender": "error",
        "noNestedPromises": "error",
        "noShadow": "error",
        "noSkippedTests": "off",
        "noUnnecessaryConditions": "off",
        "useAwait": "off"
      },
      "style": {
        "noDefaultExport": "off",
        "noContinue": "off",
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 500,
            "skipBlankLines": true
          }
        },
        "noExportedImports": "off",
        "noHexColors": "off",
        "noImplicitBoolean": "off",
        "noJsxLiterals": "error",
        "noMagicNumbers": "off",
        "noNestedTernary": "error",
        "noProcessEnv": "off",
        "noTernary": "off",
        "noParameterAssign": "error",
        "useCollapsedIf": "error",
        "useBlockStatements": "off",
        "useComponentExportOnlyModules": "off",
        "useConsistentArrayType": "error",
        "useConsistentMethodSignatures": "error",
        "useConsistentTypeDefinitions": {
          "level": "error",
          "options": {
            "style": "type"
          }
        },
        "useDefaultSwitchClause": "off",
        "useErrorCause": "error",
        "useExplicitLengthCheck": "error",
        "useExportsLast": "off",
        "useGlobalThis": "off",
        "useNamingConvention": "off",
        "useNumericSeparators": "off",
        "useReadonlyClassProperties": "error",
        "useDestructuring": "off"
      },
      "performance": {
        "noAwaitInLoops": "off",
        "noBarrelFile": "off",
        "noJsxPropsBind": "off",
        "noNamespaceImport": "off",
        "useTopLevelRegex": "off"
      },
      "security": {
        "noSecrets": {
          "level": "error",
          "options": {
            "entropyThreshold": 80
          }
        }
      }
    },
    "domains": {
      "drizzle": "none",
      "next": "all",
      "playwright": "all",
      "project": "all",
      "qwik": "none",
      "react": "all",
      "reactNative": "none",
      "solid": "none",
      "svelte": "none",
      "tailwind": "none",
      "test": "all",
      "turborepo": "none",
      "types": "all",
      "vue": "none"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.scss"],
      "formatter": {
        "enabled": false
      },
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": [
        "scripts/points-mcp.ts",
        "src/app/api/points/route.ts",
        "src/components/dashboard/disaster-dashboard.module.scss",
        "src/components/dashboard/disaster-dashboard.tsx",
        "src/components/admin/management-console.tsx",
        "src/components/map/map-shell.module.scss",
        "src/components/map/map-shell.tsx",
        "src/components/setup/setup-wizard.module.scss",
        "src/components/setup/setup-wizard.tsx",
        "src/components/admin/user-admin-console.tsx",
        "src/data/seoul-citydata-areas.ts",
        "src/lib/assembly-protests.ts",
        "src/lib/dataset-import.ts",
        "src/lib/i18n.ts",
        "src/lib/map-shell-core.ts",
        "src/lib/medical-dataset-import.ts",
        "src/lib/points-db.ts",
        "tests/e2e/home.spec.ts",
        "tests/unit/assembly-protests.test.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noExcessiveLinesPerFunction": "off"
          },
          "style": {
            "noExcessiveLinesPerFile": "off"
          }
        }
      }
    }
  ]
}
